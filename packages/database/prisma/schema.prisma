generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String?  @unique
  emailVerifiedAt  DateTime?
  displayName      String?
  telegramUserId   String?  @unique
  telegramUsername String?
  firstName        String?
  language         String   @default("ru")
  timezone         String   @default("Europe/Minsk")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  authAccounts             AuthAccount[]
  categories               Category[]
  checkSessions            CheckSession[]
  groups                   ItemGroup[]
  items                    Item[]
  ownedWorkspaces          Workspace[]              @relation("WorkspaceOwner")
  recommendationDismissals RecommendationDismissal[]
  reminders                Reminder[]
  sentWorkspaceInvitations WorkspaceInvitation[]    @relation("WorkspaceInvitationInviter")
  shoppingListItems        ShoppingListItem[]
  workspaceMemberships     WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner                    User                       @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  categories               Category[]
  checkSessions            CheckSession[]
  groups                   ItemGroup[]
  items                    Item[]
  invitations              WorkspaceInvitation[]
  members                  WorkspaceMember[]
  recommendationDismissals RecommendationDismissal[]
  reminders                Reminder[]
  shoppingListItems        ShoppingListItem[]

  @@index([ownerId])
}

model WorkspaceMember {
  id           String        @id @default(cuid())
  workspaceId  String
  userId       String
  role         WorkspaceRole @default(EDITOR)
  invitedEmail String?
  invitedAt    DateTime?
  joinedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([invitedEmail])
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String
  invitedById String
  email       String
  role        WorkspaceRole @default(EDITOR)
  tokenHash   String        @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("WorkspaceInvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId, email])
  @@index([email, createdAt])
  @@index([expiresAt])
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  email             String?
  emailVerified     Boolean      @default(false)
  displayName       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}

model MagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
  @@index([expiresAt])
}

model OAuthStateToken {
  id         String       @id @default(cuid())
  provider   AuthProvider
  stateHash  String       @unique
  nonceHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([provider, createdAt])
  @@index([expiresAt])
}

model Category {
  id              String    @id @default(cuid())
  userId          String
  workspaceId     String?
  name            String
  icon            String?
  sortOrder       Int       @default(0)
  usageCycleDays  Int?
  nextCheckAt     DateTime?
  reminderEnabled Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archivedAt      DateTime?

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  checkSessions     CheckSession[]
  items             Item[]
  reminders         Reminder[]
  shoppingListItems ShoppingListItem[]

  @@index([userId, archivedAt])
  @@index([userId, nextCheckAt])
  @@index([workspaceId, archivedAt])
  @@index([workspaceId, nextCheckAt])
}

model Item {
  id              String         @id @default(cuid())
  userId          String
  workspaceId     String?
  categoryId      String
  name            String
  brand           String?
  notes           String?
  status          ItemStatus     @default(IN_STOCK)
  importance      ItemImportance @default(NORMAL)
  usageCycleDays  Int?
  lastCheckedAt   DateTime?
  lastBoughtAt    DateTime?
  nextCheckAt     DateTime?
  reminderEnabled Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  archivedAt      DateTime?

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  checkSessionItems CheckSessionItem[]
  groupItems        ItemGroupItem[]
  reminders         Reminder[]
  shoppingListItems ShoppingListItem[]

  @@index([userId, categoryId, archivedAt])
  @@index([userId, status])
  @@index([userId, nextCheckAt])
  @@index([workspaceId, categoryId, archivedAt])
  @@index([workspaceId, status])
  @@index([workspaceId, nextCheckAt])
}

model ShoppingListItem {
  id          String           @id @default(cuid())
  userId      String
  workspaceId String?
  itemId      String?
  title       String
  categoryId  String?
  priority    ShoppingPriority @default(NORMAL)
  isCompleted Boolean          @default(false)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item      Item?      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  category  Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, isCompleted, priority])
  @@index([workspaceId, isCompleted, priority])
  @@index([itemId, isCompleted])
}

model Reminder {
  id             String         @id @default(cuid())
  userId         String
  workspaceId    String?
  type           ReminderType
  itemId         String?
  categoryId     String?
  groupId        String?
  scheduledFor   DateTime
  status         ReminderStatus @default(PENDING)
  attemptCount   Int            @default(0)
  sentAt         DateTime?
  idempotencyKey String         @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item      Item?      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  category  Category?  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, status, scheduledFor])
  @@index([workspaceId, status, scheduledFor])
  @@index([itemId, scheduledFor])
  @@index([categoryId, scheduledFor])
  @@index([groupId, scheduledFor])
}

model ItemGroup {
  id              String    @id @default(cuid())
  userId          String
  workspaceId     String?
  name            String
  icon            String?
  usageCycleDays  Int?
  nextCheckAt     DateTime?
  reminderEnabled Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archivedAt      DateTime?

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  checkSessions CheckSession[]
  items         ItemGroupItem[]

  @@index([userId, archivedAt])
  @@index([userId, nextCheckAt])
  @@index([workspaceId, archivedAt])
  @@index([workspaceId, nextCheckAt])
}

model ItemGroupItem {
  id        String   @id @default(cuid())
  groupId   String
  itemId    String
  createdAt DateTime @default(now())

  group ItemGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  item  Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([groupId, itemId])
  @@index([itemId])
}

model CheckSession {
  id          String             @id @default(cuid())
  userId      String
  workspaceId String?
  categoryId  String?
  groupId     String?
  status      CheckSessionStatus @default(IN_PROGRESS)
  startedAt   DateTime           @default(now())
  completedAt DateTime?

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category?          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group     ItemGroup?         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  items     CheckSessionItem[]

  @@index([userId, status, startedAt])
  @@index([workspaceId, status, startedAt])
  @@index([categoryId, status])
  @@index([groupId, status])
}

model CheckSessionItem {
  id             String      @id @default(cuid())
  sessionId      String
  itemId         String
  sortOrder      Int
  selectedStatus ItemStatus?
  checkedAt      DateTime?

  session CheckSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item    Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([sessionId, itemId])
  @@index([sessionId, sortOrder])
}

model RecommendationDismissal {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  ruleId        String
  suggestedItem String
  createdAt     DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, ruleId, suggestedItem])
  @@index([userId, ruleId])
  @@index([workspaceId, ruleId])
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum ItemStatus {
  IN_STOCK
  LOW
  NEED_BUY
  URGENT
  PAUSED
}

enum ItemImportance {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ShoppingPriority {
  NORMAL
  URGENT
}

enum ReminderType {
  ITEM_CHECK
  CATEGORY_CHECK
  GROUP_CHECK
  SHOPPING_REMINDER
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum AuthProvider {
  GOOGLE
  APPLE
}

enum CheckSessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
