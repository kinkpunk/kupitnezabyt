# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kupitnezabyt

# Redis (optional legacy/queue flows)
REDIS_URL=redis://localhost:6379

# Web app
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_PORT=3001

# Auth
JWT_SECRET=replace_me
EMAIL_FROM=
EMAIL_PROVIDER_API_KEY=
MAGIC_LINK_TOKEN_TTL_MINUTES=15

# Optional OAuth sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:3001/api/auth/apple/callback

# Optional Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBAPP_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Optional
DEV_AUTH_ENABLED=false
LOG_LEVEL=info
WORKER_POLL_INTERVAL_MS=300000
REMINDER_BATCH_SIZE=25
REMINDER_MAX_ATTEMPTS=5
